# Inclusive AI Trust Gateway environment template.
# Copy to .env.local for local development, or add the matching variables in
# Choreo, Vercel, GitHub Actions, Neon, Supabase, Upstash, and HiveMQ.
#
# Do not commit real secrets. Values below are examples/placeholders only.


###############################################################################
# Public frontend config - Vercel / Next.js
###############################################################################

# Browser-visible gateway API origin. No trailing slash.
NEXT_PUBLIC_API_BASE_URL=https://<trust-gateway-choreo-public-url>

# Browser-visible demo API key used by apps/web/lib/api.ts.
# OK for hackathon demos; for production proxy requests through a server route
# and keep GATEWAY_API_KEY server-only.
NEXT_PUBLIC_API_KEY=replace-with-demo-gateway-api-key

# Server-side Vercel proxy settings used by apps/web/app/api/gateway/[...path].
# Prefer these for production so browser fetches hit /api/gateway/* and avoid
# exposing the real gateway key in client code.
GATEWAY_API_BASE_URL=https://<trust-gateway-choreo-public-url>
# Also set GATEWAY_API_KEY on Vercel using the value from the gateway section.

# Expo mobile uses EXPO_PUBLIC_* names. Keep these aligned with the web vars
# when building apps/mobile.
EXPO_PUBLIC_API_BASE_URL=https://<vercel-app>.vercel.app/api/gateway
EXPO_PUBLIC_API_KEY=replace-with-demo-gateway-api-key

# Optional alias for scripts/tools that expect API_URL instead of the Next.js
# public variable. The current web app uses NEXT_PUBLIC_API_BASE_URL.
API_URL=https://<trust-gateway-choreo-public-url>


###############################################################################
# Trust gateway container - Choreo / local Docker
###############################################################################

# HTTP port inside the container. Choreo endpoint port must match (8080).
GATEWAY_PORT=8080

# Required for all /v1, /graphql, /mcp, /ucp/v1, and Connect-RPC endpoints.
# Send as X-Api-Key from server clients, or as NEXT_PUBLIC_API_KEY for demos.
GATEWAY_API_KEY=replace-with-long-random-api-key

# HMAC secret used for outbound webhook signing.
WEBHOOK_SECRET=replace-with-long-random-webhook-secret

# Optional ERH engine base URL. Empty means the gateway uses fallback scoring.
# Choreo erh-engine component public URL (set on gateway after ERH deploy).
ERH_SERVICE_URL=

# Optional timeout for ERH calls. Go duration syntax: 2s, 500ms, 1m.
ERH_TIMEOUT=5s

# Browser CORS allowlist for Vercel/localhost frontends. Empty or * allows
# any origin for the demo; production should list exact origins.
CORS_ALLOWED_ORIGINS=https://your-vercel-frontend.vercel.app,http://localhost:3000


###############################################################################
# Postgres - Neon primary and Supabase warm backup
###############################################################################

# Runtime Postgres connection string. For production, point this at Neon pooled
# Postgres first. During failover, swap it to Supabase's pooled connection.
# Local compose example:
# DATABASE_URL=postgres://iatg:iatg@postgres:5432/iatg?sslmode=disable
DATABASE_URL=postgresql://gateway_rw:password@ep-example-pooler.region.aws.neon.tech/iatg?sslmode=require

# Neon URLs used by migration/backup scripts and CI.
# Use the pooled URL for app runtime and the direct URL for migrations/admin jobs.
NEON_DATABASE_URL=postgresql://gateway_rw:password@ep-example-pooler.region.aws.neon.tech/iatg?sslmode=require
NEON_DIRECT_DATABASE_URL=postgresql://owner:password@ep-example.region.aws.neon.tech/iatg?sslmode=require

# Supabase URLs used as warm backup / failover target.
# Use transaction pooler port 6543 for app runtime; use port 5432 for migrations.
SUPABASE_DATABASE_URL=postgresql://gateway_rw:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DIRECT_DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# Optional Supabase API settings if a frontend/admin tool later talks to
# Supabase directly. The current gateway uses Postgres URLs, not these keys.
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key


###############################################################################
# Redis event bus - in-process, Upstash, or local Docker
###############################################################################

# Empty REDIS_URL makes the gateway use an in-process event bus.
# Local compose: redis://redis:6379/0
# Upstash example: rediss://default:password@host.upstash.io:6379
REDIS_URL=

UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token


###############################################################################
# MQTT broker - disabled, HiveMQ Cloud, or local Docker
###############################################################################

# Empty MQTT_URL disables MQTT subscription.
# Local compose: tcp://mosquitto:1883
# TLS broker example: ssl://broker.example.s1.eu.hivemq.cloud:8883
MQTT_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# Optional HiveMQ Cloud metadata for deploy notes/scripts.
HIVEMQ_HOST=broker.example.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=replace-with-hivemq-user
HIVEMQ_PASSWORD=replace-with-hivemq-password


###############################################################################
# ADM engine containers / telemetry producers
###############################################################################

ADM_PORT=8080
ADM_GRPC_PORT=9090
ADM_REDIS_ADDR=redis:6379

# Webhook target for ADM producers.
ADM_WEBHOOK_URL=https://<trust-gateway-choreo-public-url>/v1/adm/events
ADM_WEBHOOK_API_KEY=replace-with-gateway-api-key


###############################################################################
# Test automation
###############################################################################

# Robot API tests read GATEWAY_API_KEY directly and accept BASE_URL as a
# variable. Keep these aligned with the deployed gateway.
BASE_URL=https://<trust-gateway-choreo-public-url>
APP_URL=https://your-vercel-frontend.vercel.app


###############################################################################
# Deployment metadata - optional
###############################################################################

# Choreo component public URLs (copy from console after deploy)
CHOREO_GATEWAY_URL=https://<trust-gateway-choreo-public-url>
CHOREO_ADM_URL=https://<adm-stack-choreo-public-url>
CHOREO_ERH_URL=https://<erh-engine-choreo-public-url>

# Vercel / Expo also need:
ADM_API_BASE_URL=https://<adm-stack-choreo-public-url>
ERH_API_BASE_URL=https://<erh-engine-choreo-public-url>
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
